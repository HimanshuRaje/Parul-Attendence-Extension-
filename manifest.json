{
  "manifest_version": 3,
  "name": "Parul Attendance",
  "version": "1.0",
  "description": "One-click attendance checker for Parul University UMS",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://ums.paruluniversity.ac.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://ums.paruluniversity.ac.in/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "32": "icon.png"
  }
}
